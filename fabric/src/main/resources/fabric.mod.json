{
    "schemaVersion": 1,
    "id": "shyne_creator",
    "version": "${version}",
    "name": "Shyne Creator",
    "description": "Create multiplayer-ready avatars, custom items, skills, powers, and combat systems with Lua and Blockbench.",
    "authors": ["seashyne"],
    "contact": {
        "homepage": "https://www.curseforge.com/minecraft/mc-mods/shyne-creator",
        "sources":  "https://github.com/seashyne/ShyneCore"
    },
    "license": "GPL-3.0-only",
    "icon": "assets/shyne_creator/icon.png",
    "environment": "*",
    "entrypoints": {
        "main":   ["seashyne.shynecore.ShyneCore"],
        "client": ["seashyne.shynecore.client.ShyneCoreClient"],
        "voicechat": ["seashyne.shynecore.voice.ShyneVoicechatPlugin"]
    },
    "mixins": [
        "shyne_creator.mixins.json",
        { "config": "shyne_creator.client.mixins.json", "environment": "client" }
    ],
    "depends": {
        "fabricloader": ">=0.19.3",
        "minecraft":    "~26.2",
        "java":         ">=25",
        "fabric-api":   "*"
    },
    "suggests": {
        "voicechat_api": ">=2.6.20"
    }
}
