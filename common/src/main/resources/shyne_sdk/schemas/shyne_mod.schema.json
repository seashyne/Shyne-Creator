{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shyne Mod Manifest",
  "type": "object",
  "required": [
    "id"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "author": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "script_engine": {
      "enum": [
        "lua"
      ]
    },
    "entry": {
      "type": "string"
    }
  }
}
